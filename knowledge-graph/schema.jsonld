{
  "@context": {
    "@vocab": "https://github.com/aztecher/cwkr/ontology#",
    "cwkr": "https://github.com/aztecher/cwkr/ontology#",
    "schema": "https://schema.org/",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "cwkr:Ontology",
      "@type": "owl:Ontology",
      "rdfs:label": "CKWR Knowledge Graph Ontology",
      "rdfs:comment": "Ontology for tracking discussions in llm-d and Kubernetes Slack communities."
    },

    {"@id": "cwkr:Entity", "@type": "owl:Class", "rdfs:label": "Entity", "rdfs:comment": "Base class for all entities in the graph."},
    {"@id": "cwkr:Person", "@type": "owl:Class", "rdfs:subClassOf": {"@id": "cwkr:Entity"}, "rdfs:label": "Person"},
    {"@id": "cwkr:Project", "@type": "owl:Class", "rdfs:subClassOf": {"@id": "cwkr:Entity"}, "rdfs:label": "Project"},
    {"@id": "cwkr:Component", "@type": "owl:Class", "rdfs:subClassOf": {"@id": "cwkr:Entity"}, "rdfs:label": "Component", "rdfs:comment": "A SIG, sub-project, or module within a Project."},
    {"@id": "cwkr:Discussion", "@type": "owl:Class", "rdfs:subClassOf": {"@id": "cwkr:Entity"}, "rdfs:label": "Discussion", "rdfs:comment": "A conversation thread or message in a Slack channel."},
    {"@id": "cwkr:Issue", "@type": "owl:Class", "rdfs:subClassOf": {"@id": "cwkr:Entity"}, "rdfs:label": "Issue", "rdfs:comment": "A GitHub issue or bug report."},
    {"@id": "cwkr:PullRequest", "@type": "owl:Class", "rdfs:subClassOf": {"@id": "cwkr:Entity"}, "rdfs:label": "PullRequest"},
    {"@id": "cwkr:Feature", "@type": "owl:Class", "rdfs:subClassOf": {"@id": "cwkr:Entity"}, "rdfs:label": "Feature"},
    {"@id": "cwkr:Concept", "@type": "owl:Class", "rdfs:subClassOf": {"@id": "cwkr:Entity"}, "rdfs:label": "Concept", "rdfs:comment": "A technical concept, algorithm, or methodology."},
    {"@id": "cwkr:Tool", "@type": "owl:Class", "rdfs:subClassOf": {"@id": "cwkr:Entity"}, "rdfs:label": "Tool", "rdfs:comment": "A software tool or framework."},

    {"@id": "cwkr:participatesIn", "@type": "owl:ObjectProperty", "rdfs:domain": {"@id": "cwkr:Person"}, "rdfs:range": {"@id": "cwkr:Discussion"}, "rdfs:label": "participates in"},
    {"@id": "cwkr:relatedTo", "@type": "owl:ObjectProperty", "rdfs:domain": {"@id": "cwkr:Entity"}, "rdfs:range": {"@id": "cwkr:Entity"}, "rdfs:label": "related to"},
    {"@id": "cwkr:partOf", "@type": "owl:ObjectProperty", "rdfs:domain": {"@id": "cwkr:Component"}, "rdfs:range": {"@id": "cwkr:Project"}, "rdfs:label": "part of"},
    {"@id": "cwkr:mentions", "@type": "owl:ObjectProperty", "rdfs:domain": {"@id": "cwkr:Discussion"}, "rdfs:range": {"@id": "cwkr:Entity"}, "rdfs:label": "mentions"},
    {"@id": "cwkr:resolves", "@type": "owl:ObjectProperty", "rdfs:domain": {"@id": "cwkr:PullRequest"}, "rdfs:range": {"@id": "cwkr:Issue"}, "rdfs:label": "resolves"},
    {"@id": "cwkr:dependsOn", "@type": "owl:ObjectProperty", "rdfs:domain": {"@id": "cwkr:Entity"}, "rdfs:range": {"@id": "cwkr:Entity"}, "rdfs:label": "depends on"},
    {"@id": "cwkr:createdBy", "@type": "owl:ObjectProperty", "rdfs:domain": {"@id": "cwkr:Entity"}, "rdfs:range": {"@id": "cwkr:Person"}, "rdfs:label": "created by"},
    {"@id": "cwkr:occursIn", "@type": "owl:ObjectProperty", "rdfs:domain": {"@id": "cwkr:Discussion"}, "rdfs:range": {"@id": "cwkr:Component"}, "rdfs:label": "occurs in"},

    {"@id": "cwkr:name", "@type": "owl:DatatypeProperty", "rdfs:range": {"@id": "xsd:string"}, "rdfs:label": "name"},
    {"@id": "cwkr:slackId", "@type": "owl:DatatypeProperty", "rdfs:range": {"@id": "xsd:string"}, "rdfs:label": "Slack user ID"},
    {"@id": "cwkr:url", "@type": "owl:DatatypeProperty", "rdfs:range": {"@id": "xsd:anyURI"}, "rdfs:label": "URL"},
    {"@id": "cwkr:timestamp", "@type": "owl:DatatypeProperty", "rdfs:range": {"@id": "xsd:dateTime"}, "rdfs:label": "timestamp"},
    {"@id": "cwkr:summary", "@type": "owl:DatatypeProperty", "rdfs:range": {"@id": "xsd:string"}, "rdfs:label": "summary"},
    {"@id": "cwkr:sentiment", "@type": "owl:DatatypeProperty", "rdfs:range": {"@id": "xsd:string"}, "rdfs:label": "sentiment", "rdfs:comment": "positive | negative | neutral"},
    {"@id": "cwkr:source", "@type": "owl:DatatypeProperty", "rdfs:range": {"@id": "xsd:string"}, "rdfs:label": "source channel"}
  ]
}
