{
  "@context": {
    "@vocab": "https://github.com/aztecher/ckwr/ontology#",
    "ckwr": "https://github.com/aztecher/ckwr/ontology#",
    "schema": "https://schema.org/",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "ckwr:Ontology",
      "@type": "owl:Ontology",
      "rdfs:label": "CKWR Knowledge Graph Ontology",
      "rdfs:comment": "Ontology for tracking discussions in llm-d and Kubernetes Slack communities."
    },

    {"@id": "ckwr:Entity", "@type": "owl:Class", "rdfs:label": "Entity", "rdfs:comment": "Base class for all entities in the graph."},
    {"@id": "ckwr:Person", "@type": "owl:Class", "rdfs:subClassOf": {"@id": "ckwr:Entity"}, "rdfs:label": "Person"},
    {"@id": "ckwr:Project", "@type": "owl:Class", "rdfs:subClassOf": {"@id": "ckwr:Entity"}, "rdfs:label": "Project"},
    {"@id": "ckwr:Component", "@type": "owl:Class", "rdfs:subClassOf": {"@id": "ckwr:Entity"}, "rdfs:label": "Component", "rdfs:comment": "A SIG, sub-project, or module within a Project."},
    {"@id": "ckwr:Discussion", "@type": "owl:Class", "rdfs:subClassOf": {"@id": "ckwr:Entity"}, "rdfs:label": "Discussion", "rdfs:comment": "A conversation thread or message in a Slack channel."},
    {"@id": "ckwr:Issue", "@type": "owl:Class", "rdfs:subClassOf": {"@id": "ckwr:Entity"}, "rdfs:label": "Issue", "rdfs:comment": "A GitHub issue or bug report."},
    {"@id": "ckwr:PullRequest", "@type": "owl:Class", "rdfs:subClassOf": {"@id": "ckwr:Entity"}, "rdfs:label": "PullRequest"},
    {"@id": "ckwr:Feature", "@type": "owl:Class", "rdfs:subClassOf": {"@id": "ckwr:Entity"}, "rdfs:label": "Feature"},
    {"@id": "ckwr:Concept", "@type": "owl:Class", "rdfs:subClassOf": {"@id": "ckwr:Entity"}, "rdfs:label": "Concept", "rdfs:comment": "A technical concept, algorithm, or methodology."},
    {"@id": "ckwr:Tool", "@type": "owl:Class", "rdfs:subClassOf": {"@id": "ckwr:Entity"}, "rdfs:label": "Tool", "rdfs:comment": "A software tool or framework."},

    {"@id": "ckwr:participatesIn", "@type": "owl:ObjectProperty", "rdfs:domain": {"@id": "ckwr:Person"}, "rdfs:range": {"@id": "ckwr:Discussion"}, "rdfs:label": "participates in"},
    {"@id": "ckwr:relatedTo", "@type": "owl:ObjectProperty", "rdfs:domain": {"@id": "ckwr:Entity"}, "rdfs:range": {"@id": "ckwr:Entity"}, "rdfs:label": "related to"},
    {"@id": "ckwr:partOf", "@type": "owl:ObjectProperty", "rdfs:domain": {"@id": "ckwr:Component"}, "rdfs:range": {"@id": "ckwr:Project"}, "rdfs:label": "part of"},
    {"@id": "ckwr:mentions", "@type": "owl:ObjectProperty", "rdfs:domain": {"@id": "ckwr:Discussion"}, "rdfs:range": {"@id": "ckwr:Entity"}, "rdfs:label": "mentions"},
    {"@id": "ckwr:resolves", "@type": "owl:ObjectProperty", "rdfs:domain": {"@id": "ckwr:PullRequest"}, "rdfs:range": {"@id": "ckwr:Issue"}, "rdfs:label": "resolves"},
    {"@id": "ckwr:dependsOn", "@type": "owl:ObjectProperty", "rdfs:domain": {"@id": "ckwr:Entity"}, "rdfs:range": {"@id": "ckwr:Entity"}, "rdfs:label": "depends on"},
    {"@id": "ckwr:createdBy", "@type": "owl:ObjectProperty", "rdfs:domain": {"@id": "ckwr:Entity"}, "rdfs:range": {"@id": "ckwr:Person"}, "rdfs:label": "created by"},
    {"@id": "ckwr:occursIn", "@type": "owl:ObjectProperty", "rdfs:domain": {"@id": "ckwr:Discussion"}, "rdfs:range": {"@id": "ckwr:Component"}, "rdfs:label": "occurs in"},

    {"@id": "ckwr:name", "@type": "owl:DatatypeProperty", "rdfs:range": {"@id": "xsd:string"}, "rdfs:label": "name"},
    {"@id": "ckwr:slackId", "@type": "owl:DatatypeProperty", "rdfs:range": {"@id": "xsd:string"}, "rdfs:label": "Slack user ID"},
    {"@id": "ckwr:url", "@type": "owl:DatatypeProperty", "rdfs:range": {"@id": "xsd:anyURI"}, "rdfs:label": "URL"},
    {"@id": "ckwr:timestamp", "@type": "owl:DatatypeProperty", "rdfs:range": {"@id": "xsd:dateTime"}, "rdfs:label": "timestamp"},
    {"@id": "ckwr:summary", "@type": "owl:DatatypeProperty", "rdfs:range": {"@id": "xsd:string"}, "rdfs:label": "summary"},
    {"@id": "ckwr:sentiment", "@type": "owl:DatatypeProperty", "rdfs:range": {"@id": "xsd:string"}, "rdfs:label": "sentiment", "rdfs:comment": "positive | negative | neutral"},
    {"@id": "ckwr:source", "@type": "owl:DatatypeProperty", "rdfs:range": {"@id": "xsd:string"}, "rdfs:label": "source channel"}
  ]
}
